root = Stack([hero, gallery, codeExample, pricing, testimonials, footer], "column", "l", "stretch", "start")

hero = Card([
  Stack([heroImage, heroText], "row", "l", "center", "between", false),
])
heroImage = Image("Live preview of OpenUI Lang in your IDE", "https://placehold.co/640x400/4f46e5/ffffff?text=Genui+Preview")
heroText = Stack([
  Tag("New", null, "sm", "success"),
  TextContent("Sketch UIs at the speed of thought", "large-heavy"),
  TextContent("Your AI agent writes an OpenUI Lang file. We render it live in your editor. Iterate at conversation speed.", "default"),
  Buttons([
    Button("Get started", Action([@ToAssistant("start")]), "primary"),
    Button("View on GitHub", Action([@ToAssistant("github")]), "secondary"),
  ], "row"),
], "column", "m", "start", "start")

gallery = Card([
  CardHeader("What developers built this week", "2000+ open-source .openui files from the community"),
  ImageGallery([
    { src: "https://placehold.co/400x300/ef4444/ffffff?text=Dashboard", alt: "Engineering dashboard prototype" },
    { src: "https://placehold.co/400x300/3b82f6/ffffff?text=Signup", alt: "Signup form mockup" },
    { src: "https://placehold.co/400x300/10b981/ffffff?text=Settings", alt: "Settings page" },
    { src: "https://placehold.co/400x300/f59e0b/ffffff?text=Billing", alt: "Billing screen" },
    { src: "https://placehold.co/400x300/8b5cf6/ffffff?text=Onboarding", alt: "Onboarding flow" },
    { src: "https://placehold.co/400x300/ec4899/ffffff?text=Analytics", alt: "Analytics page" },
    { src: "https://placehold.co/400x300/06b6d4/ffffff?text=Workspace", alt: "Workspace overview" },
    { src: "https://placehold.co/400x300/64748b/ffffff?text=Settings", alt: "Account settings" },
  ]),
])

codeExample = Card([
  CardHeader("It's just OpenUI Lang", "5 lines for a complete card"),
  CodeBlock("openui", "root = Stack([title, body, cta])\ntitle = TextContent(\"Hello, world\", \"large-heavy\")\nbody = TextContent(\"This is OpenUI Lang.\", \"default\")\ncta = Button(\"Get started\", Action([@ToAssistant(\"go\")]), \"primary\")"),
])

pricing = Card([
  CardHeader("Simple pricing", "Pay only for what you preview"),
  Stack([free, pro, team], "row", "m", "stretch", "start", true),
])
free = Card([
  TextContent("Free", "large-heavy"),
  TextContent("$0", "large-heavy"),
  TextContent("forever", "small"),
  Separator(),
  TextContent("• Up to 3 .openui files", "default"),
  TextContent("• OpenUI Lang format", "default"),
  TextContent("• Community support", "default"),
  Buttons([Button("Get started", Action([@ToAssistant("free")]), "secondary")]),
])
pro = Card([
  Tag("MOST POPULAR", null, "sm", "info"),
  TextContent("Pro", "large-heavy"),
  TextContent("$12", "large-heavy"),
  TextContent("per month", "small"),
  Separator(),
  TextContent("• Unlimited .openui files", "default"),
  TextContent("• All formats (json-render, A2UI…)", "default"),
  TextContent("• Priority support", "default"),
  TextContent("• Save history", "default"),
  Buttons([Button("Start free trial", Action([@ToAssistant("pro")]), "primary")]),
])
team = Card([
  TextContent("Team", "large-heavy"),
  TextContent("$40", "large-heavy"),
  TextContent("per month", "small"),
  Separator(),
  TextContent("• Everything in Pro", "default"),
  TextContent("• Shared workspace previews", "default"),
  TextContent("• SSO + audit log", "default"),
  TextContent("• SLA + dedicated support", "default"),
  Buttons([Button("Contact sales", Action([@ToAssistant("team")]), "secondary")]),
])

testimonials = Card([
  CardHeader("Loved by developers", null),
  Carousel([
    quote1, quote2, quote3, quote4,
  ]),
])
quote1 = Card([TextContent("Finally, AI prototyping that doesn't require Storybook. The save-triggered re-render fits my Claude Code flow perfectly.", "default"), TextContent("— Alex M, eng at Acme", "small")])
quote2 = Card([TextContent("Bundleability was a real concern. Genui's spike approach validated it on day one. Smart roadmap.", "default"), TextContent("— Sam K, OpenUI maintainer", "small")])
quote3 = Card([TextContent("Works in Cursor with zero config. Same .vsix as my VS Code setup. That's the dream.", "default"), TextContent("— Morgan L, designer", "small")])
quote4 = Card([TextContent("The error overlay is exactly right — last good content stays, no flashing, no modal hell. PRD §6.4 done right.", "default"), TextContent("— Reviewer on Marketplace", "small")])

footer = Card([
  Stack([
    TextContent("Genui — generative UI, previewed instantly.", "default"),
    TextContent("MIT licensed. Open source on GitHub. Zero telemetry, zero network calls, zero ads.", "small"),
  ], "column", "xs", "center", "center"),
])
