  HorizontalBarChart(
    ["OpenUI Lang", "Vercel json-render (preview)", "Google A2UI (planned)", "Open-JSON-UI (planned)"],
    [Series("Renders", [12080, 240, 0, 0])]
  ),
])

recent = Card([
