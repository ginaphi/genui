      Series("OpenUI",      [1420, 1680, 1810, 2010, 2240, 1450, 1798]),
      Series("json-render", [   0,    0,    0,    0,   80,  120,  240]),
    ]
  ),
])

errorsCard = Card([
  CardHeader("Error breakdown", "By origin"),
  PieChart(
    ["Parse", "Schema", "Network", "Other"],
    [27, 12, 5, 3],
    "donut"
  ),
])

breakdown = Card([
