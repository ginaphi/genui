root = Stack([header, kpiRow, chartsRow, breakdown, recent], "column", "l", "stretch", "start")

header = CardHeader("Genui · last 7 days", "Renders, errors, and format mix across all your .openui files")

kpiRow = Stack([kpi1, kpi2, kpi3, kpi4], "row", "m", "stretch", "start", true)
kpi1 = Card([TextContent("Renders", "small"), TextContent("12,408", "large-heavy"), Tag("+18% vs last week", null, "sm", "success")])
kpi2 = Card([TextContent("P50 render time", "small"), TextContent("23 ms", "large-heavy"), Tag("under target", null, "sm", "info")])
kpi3 = Card([TextContent("Parse errors", "small"), TextContent("47", "large-heavy"), Tag("0.4% of renders", null, "sm", "neutral")])
kpi4 = Card([TextContent("Active users", "small"), TextContent("382", "large-heavy"), Tag("+24 this week", null, "sm", "success")])

chartsRow = Stack([rendersCard, errorsCard], "row", "m", "stretch", "start", true)

rendersCard = Card([
  CardHeader("Renders per day", "Save-triggered re-renders only"),
  LineChart(
    ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"],
